# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# IDE and editors
.idea/
.vscode/
.codex/
.emergent/
.qoder/
.stitch/
.agent/
.kilo/
.playwright-mcp/
.data/

# Dependencies
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/

# Testing
/coverage
tests/

# Next.js
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# Production builds
/build
dist/

# Environment files
.env
.env.local
.env.*.local
*token.json*
*credentials.json*

# Temporary and backup files
scratch/
scripts/deleted_code.txt
*.bak
*.tmp

# One-off migration / debug scripts (not part of build)
scripts/cleanup-duplicates.js
scripts/fix-encryption.mjs
scripts/init-db.js
scripts/sync_integrations.js
scripts/test-*.js
scripts/test-*.mjs

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb
*.log
scripts/*.log
scripts/worker_output.log

# System files
.DS_Store
*.pem

# Generated outputs
graphify-out/

# Tunnel configs
tunnel-config/

# Campaign uploads (generated at runtime)
public/campaign-uploads/

# Archive files
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz

# Build caches
.cache/

# Package manager
yarn.lock

# Deployment and automation scripts (often contain secrets)
scripts/*.exp
deploy/nginx.conf
