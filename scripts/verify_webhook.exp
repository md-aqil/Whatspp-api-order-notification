#!/usr/bin/expect -f

set timeout 30
set host "187.127.154.55"
set user "aqil"
set pass "aqil@noon"

spawn ssh -o StrictHostKeyChecking=no $user@$host

expect {
    "password:" {
        send "$pass\r"
    }
    "$" {
        # Already logged in
    }
}

expect "$ "
send "curl -s http://localhost:3015/api/webhook/whatsapp\r"
expect "$ "
send "exit\r"
expect eof
