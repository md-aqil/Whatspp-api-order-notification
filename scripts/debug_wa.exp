#!/usr/bin/expect -f

set timeout 30
set host "187.127.154.55"
set user "aqil"
set pass "aqil@noon"

spawn ssh -o StrictHostKeyChecking=no $user@$host

expect {
    "password:" {
        send "$pass\r"
    }
}

expect "aqil@"
sleep 2
send "mysql -u noon -p'Noon@2024' chatflow -e 'SELECT whatsapp FROM integrations LIMIT 1' > /tmp/wa_check.txt\r"
expect "aqil@"
send "cat /tmp/wa_check.txt\r"
expect "aqil@"
send "exit\r"
expect eof
