#!/usr/bin/expect -f

set timeout 30
set host "187.127.154.55"
set user "aqil"
set pass "aqil@noon"

spawn ssh -o StrictHostKeyChecking=no $user@$host

expect {
    "password:" {
        send "$pass\r"
    }
}

expect "aqil@"
sleep 1
send "sudo pm2 status\r"
expect {
    "assword" {
        send "$pass\r"
        exp_continue
    }
    "aqil@"
}
send "sudo pm2 logs --lines 50 --no-colors\r"
sleep 5
send "\x03"
expect "aqil@"
send "exit\r"
expect eof
