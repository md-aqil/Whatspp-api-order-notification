#!/usr/bin/expect -f

set timeout 30
set host "187.127.154.55"
set user "aqil"
set pass "aqil@noon"

spawn ssh -o StrictHostKeyChecking=no $user@$host

expect {
    "password:" {
        send "$pass\r"
    }
}

expect "aqil@"
sleep 1
send "sudo journalctl -u lcsw-worker -n 100 --no-pager > /tmp/worker_debug.log\r"
expect {
    "password" {
        send "$pass\r"
        exp_continue
    }
    "aqil@"
}
send "cat /tmp/worker_debug.log\r"
expect "aqil@"
send "exit\r"
expect eof
