#!/usr/bin/expect -f

set timeout 30
set host "187.127.154.55"
set user "aqil"
set pass "aqil@noon"

log_file /Users/mdaqil/Documents/chatflow/scripts/worker_output.log

spawn ssh -o StrictHostKeyChecking=no $user@$host

expect {
    "password:" {
        send "$pass\r"
    }
}

expect "aqil@"
sleep 1
send "sudo journalctl -u lcsw-worker -n 50 --no-pager\r"
expect {
    "password" {
        send "$pass\r"
        exp_continue
    }
    "aqil@"
}
send "exit\r"
expect eof
