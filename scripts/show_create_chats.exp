        # Already logged in
    }
}

expect "$ "
send "mysql -u root -p'5nUiTR3JBIjL-.7Gx1U;' -e 'SHOW CREATE TABLE lcsw_db.chats;' \r"
expect "$ "
send "exit\r"
expect eof
