#!/usr/bin/expect -f
set timeout 10
set host "187.127.154.55"
set user "root"
set password "5nUiTR3JBIjL-.7Gx1U;"

spawn ssh -o StrictHostKeyChecking=no $user@$host
expect "password:"
send "$password\r"
expect "# "

# Check for running processes to see how Next.js is started
send "ps aux | grep next\r"
expect "# "

# Check PM2 if it's installed
send "pm2 list\r"
expect "# "

send "exit\r"
expect eof
