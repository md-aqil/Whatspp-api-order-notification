#!/usr/bin/expect -f
set timeout 10
set host "187.127.154.55"
set user "root"
set password "5nUiTR3JBIjL-.7Gx1U;"

spawn ssh -o StrictHostKeyChecking=no $user@$host
expect "password:"
send "$password\r"
expect "# "

send "pm2 logs whatsapp-commerce-hub --lines 50\r"
# Wait for 5 seconds to let the logs appear
sleep 5
# Send Ctrl+C to stop the logs
send "\x03"
expect "# "

send "exit\r"
expect eof
