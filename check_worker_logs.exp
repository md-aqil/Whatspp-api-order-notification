#!/usr/bin/expect -f

set timeout 30
set host "187.127.154.55"
set user "aqil"
set pass "aqil@noon"

spawn ssh -o ConnectTimeout=10 -o StrictHostKeyChecking=no $user@$host

expect {
    "password:" {
        send "$pass\r"
    }
    -re ".*\[$#\] " { }
}

expect -re ".*\[$#\] "
send "sudo journalctl -u lcsw-worker.service -n 100 --no-pager\r"
expect {
    "Password:" {
        send "$pass\r"
    }
}
expect -re ".*\[$#\] "
send "exit\r"
expect eof
